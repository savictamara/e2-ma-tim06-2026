<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/go_register"
            android:textColor="@color/text_main"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_step" android:hint="@string/email" android:inputType="textEmailAddress" android:padding="12dp" android:textColor="@color/input_text_color" android:textColorHint="@color/input_hint_color"/>
        <EditText android:id="@+id/etUsername" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_step" android:hint="@string/username" android:padding="12dp" android:textColor="@color/input_text_color" android:textColorHint="@color/input_hint_color"/>
        <TextView
            android:id="@+id/tvRegionMapLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Izaberite region na mapi"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <rs.ac.uns.ftn.slagalica.RegionMapView
            android:id="@+id/registerRegionMap"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="8dp" />

        <EditText android:id="@+id/etRegion" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_step" android:enabled="false" android:hint="@string/region" android:padding="12dp" android:textColor="@color/input_text_color" android:textColorHint="@color/input_hint_color"/>
        <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_step" android:hint="@string/password" android:inputType="textPassword" android:padding="12dp" android:textColor="@color/input_text_color" android:textColorHint="@color/input_hint_color"/>
        <EditText android:id="@+id/etRepeatPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_step" android:hint="@string/repeat_password" android:inputType="textPassword" android:padding="12dp" android:textColor="@color/input_text_color" android:textColorHint="@color/input_hint_color"/>

        <Button
            android:id="@+id/btnRegisterSubmit"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/register_action"
            android:textColor="@color/text_main" />

        <TextView
            android:id="@+id/tvRegisterMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_muted" />
    </LinearLayout>
</ScrollView>
