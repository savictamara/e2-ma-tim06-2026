<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turnir"
            android:textColor="@color/text_main"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTournamentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="Ulaz: 3 tokena. Turnir pocinje kada udju 4 igraca."
            android:textColor="@color/text_main"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnJoinTournament"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:text="Udji u turnir"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnPlayTournamentMatch"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Igraj moj mec"
            android:textColor="@color/text_main" />

        <Button
            android:id="@+id/btnResetTournament"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Reset stuck tournament"
            android:textAllCaps="false"
            android:textColor="@color/text_main" />

        <TextView
            android:id="@+id/tvTournamentPlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="Igraci: 0/4"
            android:textColor="@color/text_main"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvTournamentFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_profile_chart_card"
            android:gravity="center"
            android:padding="16dp"
            android:text="FINAL\n?"
            android:textColor="@color/text_main"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTournamentSf1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:padding="12dp"
                android:text="SF1\n?"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTournamentSf2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:padding="12dp"
                android:text="SF2\n?"
                android:textColor="@color/text_main"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTournamentWinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:padding="16dp"
            android:text="Pobednik: ?"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
