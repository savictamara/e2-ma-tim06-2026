<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/include_game_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skocko_title"
            android:textColor="@color/game_text_color"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView android:id="@+id/tvRound" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/game_text_color" android:textSize="12sp" />
        <TextView android:id="@+id/tvCurrentPlayer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:textColor="@color/game_text_color" android:textSize="12sp" />
        <TextView android:id="@+id/tvTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:textColor="@color/game_text_color" android:textSize="12sp" />
        <TextView android:id="@+id/tvScoreP1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/game_text_color" android:visibility="gone" />
        <TextView android:id="@+id/tvScoreP2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/game_text_color" android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/skocko_pick_hint"
                android:textColor="@color/game_text_color"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/skocko_feedback_hint"
                android:textColor="@color/game_text_color"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/paletteBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivPaletteS"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="S"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/skocko" />

                <ImageView
                    android:id="@+id/ivPaletteK"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="K"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/black_square" />

                <ImageView
                    android:id="@+id/ivPaletteO"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="O"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/circle" />

                <ImageView
                    android:id="@+id/ivPaletteH"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="H"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/heart_2" />

                <ImageView
                    android:id="@+id/ivPaletteT"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="T"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/triangle" />

                <ImageView
                    android:id="@+id/ivPaletteZ"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="Z"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/star" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivGuessSlot1"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="@string/skocko_slot_empty"
                    android:padding="4dp"
                    android:scaleType="centerInside" />

                <ImageView
                    android:id="@+id/ivGuessSlot2"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="@string/skocko_slot_empty"
                    android:padding="4dp"
                    android:scaleType="centerInside" />

                <ImageView
                    android:id="@+id/ivGuessSlot3"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="@string/skocko_slot_empty"
                    android:padding="4dp"
                    android:scaleType="centerInside" />

                <ImageView
                    android:id="@+id/ivGuessSlot4"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_step"
                    android:contentDescription="@string/skocko_slot_empty"
                    android:padding="4dp"
                    android:scaleType="centerInside" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView android:id="@+id/row1slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row1slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row1slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row1slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <TextView android:id="@+id/row1feedback" android:layout_width="128dp" android:layout_height="40dp" android:layout_marginStart="6dp" android:background="@drawable/bg_step" android:gravity="center" android:text="M:0 S:0" android:textColor="@color/game_text_color" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <ImageView android:id="@+id/row2slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row2slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row2slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row2slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <TextView android:id="@+id/row2feedback" android:layout_width="128dp" android:layout_height="40dp" android:layout_marginStart="6dp" android:background="@drawable/bg_step" android:gravity="center" android:text="M:0 S:0" android:textColor="@color/game_text_color" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <ImageView android:id="@+id/row3slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row3slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row3slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row3slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <TextView android:id="@+id/row3feedback" android:layout_width="128dp" android:layout_height="40dp" android:layout_marginStart="6dp" android:background="@drawable/bg_step" android:gravity="center" android:text="M:0 S:0" android:textColor="@color/game_text_color" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <ImageView android:id="@+id/row4slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row4slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row4slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row4slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <TextView android:id="@+id/row4feedback" android:layout_width="128dp" android:layout_height="40dp" android:layout_marginStart="6dp" android:background="@drawable/bg_step" android:gravity="center" android:text="M:0 S:0" android:textColor="@color/game_text_color" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <ImageView android:id="@+id/row5slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row5slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row5slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row5slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <TextView android:id="@+id/row5feedback" android:layout_width="128dp" android:layout_height="40dp" android:layout_marginStart="6dp" android:background="@drawable/bg_step" android:gravity="center" android:text="M:0 S:0" android:textColor="@color/game_text_color" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <ImageView android:id="@+id/row6slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row6slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row6slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <ImageView android:id="@+id/row6slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginStart="4dp" android:layout_weight="1" android:background="@drawable/bg_step" android:contentDescription="@string/skocko_slot_empty" android:padding="6dp" android:scaleType="centerInside" />
                    <TextView android:id="@+id/row6feedback" android:layout_width="128dp" android:layout_height="40dp" android:layout_marginStart="6dp" android:background="@drawable/bg_step" android:gravity="center" android:text="M:0 S:0" android:textColor="@color/game_text_color" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <Button android:id="@+id/btnCheck" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="5dp" android:background="@drawable/bg_button_primary" android:text="@string/skocko_check" android:textColor="@color/white" />
            <Button
                android:id="@+id/btnNextRound"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/skocko_next_round"
                android:textColor="@color/game_text_color"
                android:visibility="gone" />

            <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/game_text_color" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
