<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_avatar_dialog_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Postavi izazov"
        android:textColor="@color/text_main"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Izaberite ulog. Zvezde maksimalno 10, tokeni maksimalno 2."
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etDialogChallengeStars"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input"
        android:hint="Zvezde 0-10"
        android:inputType="number"
        android:maxLength="2"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_muted" />

    <EditText
        android:id="@+id/etDialogChallengeTokens"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_input"
        android:hint="Tokeni 0-2"
        android:inputType="number"
        android:maxLength="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_muted" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelRegionChallenge"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Odustani"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPostRegionChallenge"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Objavi izazov"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
