<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/korak_title"
            android:textColor="@color/text_main"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/round_one_of_two"
            android:textColor="@color/text_muted" />

        <TextView android:id="@+id/tvTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_muted"/>
        <TextView android:id="@+id/tvPoints" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_muted"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView android:id="@+id/step1" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_step" android:padding="10dp" android:text="1. ?"/>
            <TextView android:id="@+id/step2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_step" android:padding="10dp" android:text="2. ?"/>
            <TextView android:id="@+id/step3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_step" android:padding="10dp" android:text="3. ?"/>
            <TextView android:id="@+id/step4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_step" android:padding="10dp" android:text="4. ?"/>
            <TextView android:id="@+id/step5" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_step" android:padding="10dp" android:text="5. ?"/>
            <TextView android:id="@+id/step6" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_step" android:padding="10dp" android:text="6. ?"/>
            <TextView android:id="@+id/step7" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_step" android:padding="10dp" android:text="7. ?"/>

            <EditText android:id="@+id/etSolution" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_step" android:hint="@string/hint_solution" android:padding="12dp"/>

            <Button android:id="@+id/btnOpenStep" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_button_secondary" android:text="@string/open_step" android:textColor="@color/text_main"/>
            <Button android:id="@+id/btnCheckSolution" style="@style/Widget.MaterialComponents.Button" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_button_primary" android:text="@string/check_solution" android:textColor="@color/white"/>

            <TextView android:id="@+id/tvResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/text_muted"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
